# DESRG Production Configuration
# Copy this file to .env.local and fill in your values

# Metrics API Configuration
REACT_APP_METRICS_API=http://localhost:3001/api/metrics
REACT_APP_METRICS_WS=ws://localhost:3001/metrics
REACT_APP_METRICS_TOKEN=your_metrics_api_token_here

# CI/CD Integration
REACT_APP_CI_WEBHOOK_URL=https://api.github.com/repos/YOUR_ORG/YOUR_REPO/dispatches
REACT_APP_CI_TOKEN=ghp_your_github_token_here
REACT_APP_CI_PROVIDER=github

# Report Destinations
REACT_APP_REPORT_EMAIL=reports@yourcompany.com
REACT_APP_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
REACT_APP_STORAGE_BUCKET=your-s3-or-gcs-bucket

# Feature Flags
REACT_APP_ENABLE_AUTOSYNC=true
REACT_APP_METRICS_INTERVAL=5000
REACT_APP_PERSIST_STATE=true

# Analytics (optional)
REACT_APP_ANALYTICS_ID=UA_YOUR_GOOGLE_ANALYTICS_ID
