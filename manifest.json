{
  "manifest_version": 3,
  "name": "DarkHub - Custom Obsidian Theme",
  "version": "1.0.0",
  "description": "A streamlined, lightweight extension to apply custom high-contrast dark styles to github.com.",
  "author": "Joshua Eugene Newton",
  "permissions": [
    "activeTab"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://*.github.com/*"
      ],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
